# --- Shared / Global ---
PROJECT_NAME=emz-view
MONGODB_URI=mongodb://mongo:27017/emz
JWT_SECRET=super-secret-key-change-it
BOT_SHARED_SECRET=another-secret-for-bot-auth

# TMDB API (Required)
TMDB_API_KEY=YOUR_TMDB_API_KEY_HERE

# --- Backend ---
PORT=8080
CORS_ORIGIN=http://localhost:5173
ML_SERVICE_URL=http://ml-service:8000
RECOMMENDATIONS_CACHE_TTL_SEC=120
SYNC_CONCURRENCY=6

# Optional LLM
LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=http://ollama:11434/v1
OPENAI_MODEL=llama3.2:3b

# --- ML Service ---
ML_PORT=8000
MODEL_PATH=./models
COLLAB_MIN_INTERACTIONS=5

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
BACKEND_URL=http://backend:8080
FRONTEND_URL=http://localhost:5173

# --- Frontend (Vite) ---
# Note: Vite requires VITE_ prefix for client-side vars
VITE_BACKEND_URL=http://localhost:8080
